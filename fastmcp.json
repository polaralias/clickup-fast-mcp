{
  "$schema": "https://gofastmcp.com/public/schemas/fastmcp.json/v1.json",
  "source": {
    "type": "filesystem",
    "path": "server.py",
    "entrypoint": "mcp"
  },
  "environment": {
    "type": "uv",
    "python": ">=3.11",
    "project": "."
  },
  "deployment": {
    "transport": "http",
    "host": "0.0.0.0",
    "port": 8000,
    "path": "/mcp",
    "log_level": "INFO",
    "env": {
      "CLICKUP_API_TOKEN": "${CLICKUP_API_TOKEN}",
      "TEAM_ID": "${TEAM_ID}",
      "MCP_API_KEY": "${MCP_API_KEY}",
      "MCP_API_KEYS": "${MCP_API_KEYS}",
      "CLICKUP_HTTP_TIMEOUT_MS": "30000",
      "BASE_URL": "${BASE_URL}",
      "FASTMCP_TRANSPORT": "http",
      "HOST": "0.0.0.0",
      "PORT": "8000"
    }
  }
}
